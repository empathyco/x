{
  "compilerOptions": {
    "target": "es2019",
    "jsx": "preserve",
    "lib": ["esnext", "dom", "dom.iterable", "scripthost"],
    "experimentalDecorators": true,
    "baseUrl": ".",
    "rootDirs": ["src", "demo"],
    "module": "esnext",
    "moduleResolution": "node",
    "paths": {
      "@x/*": ["src/*"] // For demo purposes
    },
    "types": ["vitest/globals", "node"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "importHelpers": true,
    "noEmit": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.vue",
    "demo/**/*.ts",
    "demo/**/*.vue",
    "vitest.config.ts",
    "vitest-setup.ts"
  ],
  "exclude": ["node_modules"]
}
