{
  "name": "@empathyco/x-adapter-platform",
  "version": "1.1.1",
  "description": "A search client for the Empathy Platform API",
  "author": "Empathy Systems Corporation S.L.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/empathyco/x/tree/main/packages/x-adapter-platform#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/empathyco/x.git",
    "directory": "packages/x-adapter-platform"
  },
  "keywords": [
    "search",
    "adapter",
    "client",
    "fetch"
  ],
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "report"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "prebuild": "rm -rf dist docs report *.tgz",
    "build": "pnpm run /^build:/ && pnpm run gen:docs",
    "build:cjs": "tsc --project tsconfig.cjs.json",
    "build:esm": "tsc --project tsconfig.esm.json",
    "pack": "pnpm pack",
    "gen:model-docs": "api-extractor run -l",
    "gen:typescript-docs": "api-documenter markdown -i report -o docs",
    "gen:docs": "pnpm run gen:model-docs && pnpm run gen:typescript-docs",
    "lint": "eslint --fix",
    "lint:check": "eslint",
    "lint:inspect": "eslint --inspect-config .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:unit-coverage": "vitest run --coverage",
    "test:unit-watch": "vitest",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@empathyco/x-adapter": "8.1.1",
    "@empathyco/x-types": "10.1.1",
    "@empathyco/x-utils": "1.0.3"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "7.29.9",
    "@microsoft/api-extractor": "7.58.0",
    "@vitest/coverage-v8": "4.1.2",
    "jsdom": "28.1.0",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
