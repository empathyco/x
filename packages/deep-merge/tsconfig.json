{
  "compilerOptions": {
    "target": "es2019",
    "lib": ["dom", "esnext"],
    "rootDir": "src",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["vitest/globals"],
    "strict": true,
    "declaration": true,
    "declarationDir": "./types",
    "importHelpers": true,
    "inlineSources": true,
    "noEmit": true,
    "outDir": "./dist/cjs",
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
