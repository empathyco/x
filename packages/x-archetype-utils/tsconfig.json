{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["dom", "esnext"],
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "types": ["vitest/globals"],
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts", "vite.config.mts"],
  "exclude": ["node_modules"]
}
