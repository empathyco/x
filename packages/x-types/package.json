{
  "name": "@empathyco/x-types",
  "version": "10.1.1",
  "description": "Empathy search types",
  "author": "Empathy Systems Corporation S.L.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/empathyco/x/tree/main/packages/x-types#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/empathyco/x.git",
    "directory": "packages/x-types"
  },
  "keywords": [
    "search",
    "types",
    "models",
    "interfaces"
  ],
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/x-types.d.ts",
  "files": [
    "dist",
    "report",
    "schemas"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "vite build && pnpm run gen:docs",
    "build:watch": "vite build -w",
    "gen:model-docs": "api-extractor run -c x-types-extractor.json -l && api-extractor run -c schema-extractor.json -l && api-extractor run -l",
    "gen:typescript-docs": "api-documenter markdown -i report -o docs",
    "gen:docs": "pnpm run gen:model-docs && pnpm run gen:typescript-docs",
    "postbuild": "pnpm pack",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint --fix",
    "lint:check": "eslint",
    "lint:inspect": "eslint --inspect-config .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@empathyco/x-adapter": "8.1.1",
    "@empathyco/x-utils": "1.0.3"
  },
  "devDependencies": {
    "@microsoft/api-documenter": "7.29.9",
    "@microsoft/api-extractor": "7.58.0",
    "typescript": "5.9.3",
    "vite": "6.4.1",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
